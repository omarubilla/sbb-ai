# Sanity
NEXT_PUBLIC_SANITY_PROJECT_ID=Your_value_goes_here
NEXT_PUBLIC_SANITY_DATASET=Your_value_goes_here
NEXT_PUBLIC_SANITY_ORG_ID=Your_value_goes_here
SANITY_API_WRITE_TOKEN=Your_value_goes_here

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=Your_value_goes_here
CLERK_SECRET_KEY=Your_value_goes_here

# Dashboard Admin Access
# Only this exact user can access /dashboard and dashboard server actions.
ADMIN_EMAIL=carsten@your-domain.com
# Optional; defaults to Carsten when omitted.
ADMIN_FIRST_NAME=Carsten

# Stripe
STRIPE_SECRET_KEY=Your_value_goes_here
# stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=Your_value_goes_here

# Bankful
# API key from your Bankful merchant dashboard
BANKFUL_API_KEY=0SrFaA1cBjk5WLjuvmo6e5I0viS2V1qc
# Base URL for Bankful's API — e.g. https://api.bankful.com (no trailing slash)
BANKFUL_API_BASE_URL=Your_value_goes_here
# Bankful merchant account credentials used to sign and create hosted checkout sessions
BANKFUL_USERNAME=Your_value_goes_here
BANKFUL_PASSWORD=Your_value_goes_here
# Public HTTPS base URL used for Bankful return/callback endpoints
# Example: https://your-app.vercel.app (localhost is not supported by Bankful)
BANKFUL_CALLBACK_BASE_URL=Your_value_goes_here
# Webhook signing secret — register https://yourdomain.com/api/webhooks/bankful in Bankful dashboard
BANKFUL_WEBHOOK_SECRET=Your_value_goes_here


# Vercel
AI_GATEWAY_API_KEY=Your_value_goes_here

# SEO Rank Tracking
# SerpApi key used for automated Google ranking refreshes
SERPAPI_API_KEY=Your_value_goes_here
# Shared secret used by Vercel Cron for /api/admin/seo/refresh authorization
CRON_SECRET=Your_value_goes_here

# Support Email (Resend)
# API key from Resend dashboard
RESEND_API_KEY=Your_value_goes_here
# Verified sender identity in Resend, e.g. South Bay Bio <support@yourdomain.com>
SUPPORT_EMAIL_FROM=Your_value_goes_here
# Optional sender identity specifically for pay-link invoices; falls back to SUPPORT_EMAIL_FROM
PAYLINK_EMAIL_FROM=Your_value_goes_here
# Optional recipient override. Defaults to support@south-bay-bio.com
SUPPORT_EMAIL_TO=support@south-bay-bio.com